# Copy this file to .env and fill in ONE of the keys below to upgrade
# the system from offline/rule-based mode to real LLM reasoning.
# Leave everything blank and the system still runs fully for free,
# fully offline, with a rule-based fallback.

# Option 1 - Groq (free tier, very fast): https://console.groq.com/keys
GROQ_API_KEY=

# Option 2 - Google Gemini (free tier): https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Option 3 - Ollama (100% free, local, no key needed).
# Just install Ollama and run `ollama pull llama3.1`, the system will
# auto-detect it at OLLAMA_HOST below.
OLLAMA_HOST=http://localhost:11434

# Option 4 - OpenAI (paid, used only as a last resort if set)
OPENAI_API_KEY=
