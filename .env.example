# Copy this file to .env and fill in ONE of the keys below to upgrade
# the system from offline/rule-based mode to real LLM reasoning.
# Leave everything blank and the system still runs fully for free,
# fully offline, with a rule-based fallback.

# Option 1 - Groq (free tier, very fast): https://console.groq.com/keys
GROQ_API_KEY=

# Option 2 - Google Gemini (free tier): https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Option 3 - Ollama (100% free, local, no key needed).
# Just install Ollama and run `ollama pull llama3.1`, the system will
# auto-detect it at OLLAMA_HOST below.
OLLAMA_HOST=http://localhost:11434

# Option 4 - OpenAI (paid, used only as a last resort if set)
OPENAI_API_KEY=

# Option 5 - Optional API protection for the deployed web service.
# Leave both blank to keep the current behavior (open API, generous rate limit).
#
# RATE_LIMIT: caps requests per IP per minute so a single visitor/bot can't
# exhaust your free LLM quota. Safe to enable any time -- doesn't affect the
# built-in chat page.
KG_RATE_LIMIT_PER_MINUTE=20
#
# API_KEY: requires an `X-API-Key` header on every /query call. Only enable
# this if you're using the service as a pure backend API (e.g. from your own
# script or another app) -- the built-in chat page at "/" does NOT send this
# header (a secret can't be safely embedded in public HTML), so setting this
# will also lock out the web UI. Leave blank to keep the demo page working.
API_KEY=
